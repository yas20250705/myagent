# LLM Model Settings
# プロバイダとモデルを環境変数で切り替え可能（config.tomlより優先）
# MYAGENT_LLM_PROVIDER=openai
# MYAGENT_LLM_MODEL=gpt-5-nano
# MYAGENT_LLM_FALLBACK_PROVIDER=gemini
# MYAGENT_LLM_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# API Keys
# このファイルをコピーして .env を作成し、実際のAPIキーを設定してください
# cp .env.example .env

# OpenAI API Key
# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# Google API Key (Gemini)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Exa AI API Key (Web検索ツール: websearch)
# https://dashboard.exa.ai/api-keys
EXA_API_KEY=your-exa-api-key...

# LangSmith (トレース・モニタリング)
# https://smith.langchain.com/ でAPIキーを取得
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=myagent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
